# Скопировать в .env и заполнить для своего окружения.

# БД (если не задано — SQLite-файл в data/app.db).
DATABASE_URL=postgresql+psycopg://emailai:emailai@localhost:5432/emailai

# Секрет для JWT. В проде обязательно сменить!
SECRET_KEY=change-me

# TTL access-токена, минуты.
ACCESS_TOKEN_TTL_MINUTES=1440

# Таймаут IMAP-соединения, секунды.
IMAP_TIMEOUT_SECONDS=30

# Адрес и порт backend'а.
API_HOST=127.0.0.1
API_PORT=8000
